rules_version = '2';

// OutsourcEdge — Firestore security rules
//
// Access model:
//   • Public website: read jobs/services/testimonials/site_content; submit
//     contacts/applications/service_questionnaires (create only).
//   • Active admins: full read/write on operational collections.
//   • Suspended admins: blocked from everything (mirrors the in-app suspension).
//   • CEO: the only role that can manage the `admins` collection.
//
// The bootstrap CEO email below is always treated as CEO and can never be
// suspended or removed — keep it in sync with VITE_CEO_BOOTSTRAP_EMAIL.
//
// NOTE: every read of an admin-doc field uses `.get(field, default)` instead of
// dot access. Dot access on a MISSING key throws and fails the rule closed —
// which is why the CEO could not suspend admins whose docs only carry the
// legacy `emailaddress` field (and no `email`). `.get()` tolerates both shapes.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function bootstrapCeoEmail() {
      return 'markravencanete50@gmail.com';
    }

    // Case-insensitive comparison of the signed-in user's email to the founder's.
    function isBootstrapCeoUser() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == bootstrapCeoEmail();
    }

    function myAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    function adminExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Null-safe role/status reads — a doc missing the field is simply not active/CEO
    // rather than erroring the whole evaluation.
    function isActiveAdmin() {
      return adminExists() && myAdmin().get('status', '') == 'active';
    }

    function isCeo() {
      return isSignedIn() && (
        isBootstrapCeoUser()
        || (
          adminExists()
          && myAdmin().get('role', '') == 'ceo'
          && myAdmin().get('status', '') == 'active'
        )
      );
    }

    // Null-safe email of the *target* admin doc, tolerating the legacy
    // `emailaddress` field and a missing email entirely.
    function targetEmail() {
      return resource.data.get('email', resource.data.get('emailaddress', '')).lower();
    }

    // A target admin doc belongs to the protected founder account.
    function isFounderDoc() {
      return targetEmail() == bootstrapCeoEmail();
    }

    // ── Admin accounts (CEO-managed) ────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isCeo() || (isSignedIn() && request.auth.uid == uid);

      // Self-provision on first login: only as an active 'admin', unless the
      // signed-in user is the bootstrap CEO (who may seed their own 'ceo' doc).
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.status == 'active'
        && (
          request.resource.data.role == 'admin'
          || (request.resource.data.role == 'ceo' && isBootstrapCeoUser())
        );

      // Three independent ways an update is allowed:
      //   1. A CEO manages SOMEONE ELSE's account (never the founder's). This is
      //      the path that powers suspend / reactivate / role changes.
      //   2. The founder self-heals their own role/status (can't be locked out).
      //   3. Any user touches their own doc for benign fields (e.g. lastLoginAt)
      //      as long as role and status are unchanged.
      // The `request.auth.uid != uid` guard on (1) stops a CEO from accidentally
      // suspending themselves and getting locked out.
      allow update: if isSignedIn() && (
        (isCeo() && request.auth.uid != uid && !isFounderDoc())
        || (request.auth.uid == uid && isBootstrapCeoUser())
        || (
          request.auth.uid == uid
          && request.resource.data.get('role', '') == resource.data.get('role', '')
          && request.resource.data.get('status', '') == resource.data.get('status', '')
        )
      );

      allow delete: if isCeo()
        && request.auth.uid != uid
        && !isFounderDoc();
    }

    // ── Public website content (world-readable, admin-writable) ──────────────
    match /jobs/{id}         { allow read: if true; allow write: if isActiveAdmin(); }
    match /services/{id}     { allow read: if true; allow write: if isActiveAdmin(); }
    match /testimonials/{id} { allow read: if true; allow write: if isActiveAdmin(); }
    match /site_content/{id} { allow read: if true; allow write: if isActiveAdmin(); }

    // ── Public submissions (anyone may create; admins manage) ────────────────
    match /contacts/{id} {
      allow create: if true;
      allow read, update, delete: if isActiveAdmin();
    }
    match /applications/{id} {
      allow create: if true;
      allow read, update, delete: if isActiveAdmin();
    }
    match /service_questionnaires/{id} {
      allow create: if true;
      allow read, update, delete: if isActiveAdmin();
    }

    // ── Internal, admin-only collections ─────────────────────────────────────
    match /clients/{id}         { allow read, write: if isActiveAdmin(); }
    match /adminActivities/{id} { allow read, write: if isActiveAdmin(); }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
