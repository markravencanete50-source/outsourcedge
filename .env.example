# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Your apps > Web
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Email notifications (Resend — https://resend.com)
# When a visitor submits a careers application, a contact / book-a-call message,
# or a service inquiry, /api/notify emails the company inbox below.
# RESEND_API_KEY is required for emails to send; without it submissions are still
# saved to Firestore but no email is sent.
RESEND_API_KEY=your_resend_api_key_here
# Recipient inbox. Defaults to contact@outsourcedge.com if unset.
NOTIFY_TO_EMAIL=contact@outsourcedge.com
# Verified Resend sender. Defaults to "OutsourcEdge <notifications@outsourcedge.com>".
NOTIFY_FROM_EMAIL=OutsourcEdge <notifications@outsourcedge.com>

# Admin Credentials (Change these before going live!)
VITE_ADMIN_EMAIL=admin@outsourcedge.com
VITE_ADMIN_PASSWORD=OutsourcEdge2024!

# CEO bootstrap account — this email is always granted the CEO role on login and
# can never be suspended/removed. Keep it in sync with bootstrapCeoEmail() in
# firestore.rules. Defaults to richieann@outsourcedge.com if unset.
VITE_CEO_BOOTSTRAP_EMAIL=richieann@outsourcedge.com
